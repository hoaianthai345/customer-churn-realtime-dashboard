# Core infra
TZ=Asia/Ho_Chi_Minh
ZOOKEEPER_CLIENT_PORT=2181
KAFKA_BROKER_ID=1
KAFKA_INTERNAL_LISTENER=PLAINTEXT://kafka:9092
KAFKA_EXTERNAL_LISTENER=PLAINTEXT_HOST://localhost:29092
KAFKA_LOG_RETENTION_HOURS=48

# Kafka topics
TOPIC_MEMBER_EVENTS=member_events
TOPIC_TRANSACTION_EVENTS=transaction_events
TOPIC_USER_LOG_EVENTS=user_log_events
TOPIC_CHURN_LABEL_EVENTS=churn_label_events

# App replay settings
REPLAY_SLEEP_SECONDS=2
MAX_REPLAY_DAYS=
# Keep local replay light: start from 2017-03-01 by default.
REPLAY_START_DATE=2017-03-01
TAB1_PRECOMPUTE_START_DATE=2016-01-01
TAB1_REALTIME_START_DATE=2017-03-01

# Data paths
RAW_DATA_DIR=/opt/project/data/raw
PROCESSED_DATA_DIR=/opt/project/data/processed
MEMBERS_RAW_FILE=members_v3.csv
TRANSACTIONS_RAW_FILE=transactions_v2.csv
USER_LOGS_RAW_FILE=user_logs_v2.csv
TRAIN_RAW_FILE=train_v2.csv
MEMBERS_CLEAN_FILE=members_clean.csv
TRANSACTIONS_CLEAN_FILE=transactions_clean.csv
USER_LOGS_CLEAN_FILE=user_logs_clean.csv
TRAIN_CLEAN_FILE=train_clean.csv

# Spark
SPARK_APP_NAME=realtime-bi
SPARK_MASTER=local[*]
SPARK_CHECKPOINT_BASE=/opt/project/.checkpoints
SPARK_TRIGGER_INTERVAL=10 seconds
LOW_ACTIVITY_THRESHOLD_SECS=1800
CHURN_HIGH_RISK_THRESHOLD=0.6

# ClickHouse
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000
CLICKHOUSE_DB=realtime_bi
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=vyle1234
CLICKHOUSE_JDBC_URL=jdbc:clickhouse://clickhouse:8123/realtime_bi

# Superset
SUPERSET_SECRET_KEY=replace_with_local_dev_secret
SUPERSET_ADMIN_USER=admin
SUPERSET_ADMIN_PASSWORD=admin
SUPERSET_ADMIN_EMAIL=admin@local.dev
SUPERSET_ADMIN_FIRSTNAME=Admin
SUPERSET_ADMIN_LASTNAME=User
